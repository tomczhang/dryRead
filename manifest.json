{
  "manifest_version": 3,
  "minimum_chrome_version": "116",
  "name": "dryRead — 脱水阅读",
  "version": "1.0.0",
  "description": "脱去水分，留下真正有用的东西。会思考的 AI 阅读助手：一键判断当前页面值不值得读，提炼精华观点、新奇观点、启发与可沉淀的知识。",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "dryRead：脱水当前页面",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "src/sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["sidePanel", "storage", "scripting", "tabs", "clipboardWrite"],
  "host_permissions": ["<all_urls>"]
}
